    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// В режиме \"Run Once for Each Item\" n8n сам прогонит этот код для каждого воркфлоу\nconst data = $input.item.json;\n\nconst updatedWorkflow = {\n    id: data.id,\n    name: data.name,\n    active: data.active,\n    nodes: data.nodes,\n    connections: data.connections,\n    createdAt: data.createdAt,\n    updatedAt: new Date().toISOString()\n};\n\n// Если файла нет на Гитхабе, берем имя воркфлоу + дату\nconst fileName = data.path || `${data.name}-${new Date().toISOString().split('T')[0]}.json`;\nconst base64Content = Buffer.from(JSON.stringify(updatedWorkflow, null, 2)).toString('base64');\n\nreturn {\n    fileExists: !!data.sha,\n    url: `https://api.github.com/repos/MarinaKirzner/test_backup/contents/${encodeURIComponent(fileName)}`,\n    message: data.sha ? `Update ${data.name}` : `Create backup of ${data.name}`,\n    content: base64Content,\n    sha: data.sha || null, // Передаем SHA только если он есть\n    branch: 'main'\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1040,
        656
      ],
      "id": "44554014-53f5-4d7f-b88f-20d78d45d641",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "method": "PUT",
        "url": "={{ $json.url }}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "githubOAuth2Api",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"message\": \"{{ $json.message }}\",\n  \"content\": \"{{ $json.content }}\",\n  \"sha\": \"{{ $json.sha }}\",\n  \"branch\": \"{{ $json.branch }}\"\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
