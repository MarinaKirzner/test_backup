      "credentials": {
        "githubOAuth2Api": {
          "id": "RJf06z2ILvlW8fzd",
          "name": "GitHub account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n    let name = item.json.name;\n    let compareKey = name;\n\n    // Если в имени есть дата (например, после дефиса начинается 2026...)\n    // Улучшенная логика: отрезаем всё, что после последнего дефиса, если там дата\n    if (name.includes('-20')) {\n        compareKey = name.split('-20')[0].trim();\n    } else {\n        // Если даты нет, просто убираем .json для чистоты сравнения\n        compareKey = name.replace('.json', '');\n    }\n\n    return {\n        json: {\n            ...item.json,\n            compareKey: compareKey\n        }\n    };\n});"
      },
